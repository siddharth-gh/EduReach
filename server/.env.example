PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/edureach
JWT_SECRET=replace-with-a-secure-secret
CLIENT_URL=http://localhost:5173
GEMINI_API_KEY=replace-with-your-google-ai-studio-api-key
GOOGLE_AI_MODEL=gemma-3-27b-it
OPENAI_API_KEY=replace-with-your-openai-api-key
WHISPER_MODEL=whisper-1
# Keep false while testing to avoid paid transcription calls.
ENABLE_WHISPER_TRANSCRIPTION=false
# Optional BCP-47/ISO language code to improve transcription accuracy, e.g. en, hi, pa
# OPENAI_TRANSCRIPTION_LANGUAGE=en
